cluster:
  controlPlane:
    endpoint: https://${virtual_ip_controlplane}:6443
  network:
    cni:
      name: none
  proxy:
    disabled: true
  %{~ if node_type == "controlplane" ~}
  etcd:
    extraArgs:
      listen-metrics-urls: http://0.0.0.0:2381
  %{~ endif ~}

machine:
  install:
    image: factory.talos.dev/installer/${talos_schematic_id}:${talos_version}
  kubelet:
    extraArgs:
      rotate-server-certificates: true
  nodeLabels:
    bakseter.net/physical-node: ${physical_node_name}
  features:
    hostDNS:
      forwardKubeDNSToHost: false
  time:
    bootTimeout: 2m
  network:
    hostname: ${hostname}
    interfaces:
      - deviceSelector:
          busPath: '0*'
          driver: 'virtio_net'
        dhcp: false
        addresses:
          - ${node_ip}/24
        routes:
          - network: 0.0.0.0/0
            gateway: 192.168.30.1
        %{~ if node_type == "controlplane" ~}
        vip:
          ip: ${virtual_ip_controlplane}
        %{~ endif ~}
