FROM ghcr.io/astral-sh/uv:latest AS uv

FROM ghcr.io/goauthentik/server:2026.5.5
COPY --from=uv /uv /usr/local/bin/uv

USER root

RUN uv pip install --python /ak-root/.venv/bin/python3 \
      opentelemetry-distro \
      opentelemetry-exporter-otlp \
      opentelemetry-instrumentation-django \
      opentelemetry-instrumentation-psycopg \
    && /ak-root/.venv/bin/opentelemetry-bootstrap -a install

COPY --chown=65534:65534 gunicorn.conf.py /lifecycle/gunicorn.conf.py

USER 65534

ENTRYPOINT ["dumb-init", "--", "ak"]
